# Copy this file to .env.local and fill in your real values.
# Never commit .env.local to GitHub - it contains secret keys.

# Get these from your Paystack dashboard:
# Settings > API Keys & Webhooks
# Use your TEST keys first (they start with sk_test_ and pk_test_)
# Switch to LIVE keys (sk_live_ and pk_live_) only when you are ready to accept real payments
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Your site's public URL once deployed (e.g. https://verifyd.vercel.app)
# Used so Paystack knows where to send users back after checkout
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Vercel KV (free tier) for tracking usage stats across all visitors.
# Get these by creating a free KV database in your Vercel project dashboard
# under Storage > Create Database > KV. Vercel auto-fills these for you.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
